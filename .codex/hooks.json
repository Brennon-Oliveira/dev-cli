{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "^apply_patch$|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$(git rev-parse --show-toplevel)/.codex/hooks/post_tool_use_advice.sh\"",
            "timeout": 120,
            "statusMessage": "Running Dev CLI post-edit automation"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$(git rev-parse --show-toplevel)/.codex/hooks/stop_summary.sh\"",
            "timeout": 30,
            "statusMessage": "Running Dev CLI stop hook"
          }
        ]
      }
    ]
  }
}
